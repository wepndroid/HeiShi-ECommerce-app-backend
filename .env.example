# Local SQLite (default)
# DATABASE_URL=sqlite:///./heishi.db

# Supabase Postgres (Project Settings → Database → Connection string → URI)
# Use "Session pooler" for FastAPI. Append sslmode=require if needed.
DATABASE_URL=postgresql+psycopg2://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres?sslmode=require

JWT_SECRET=change-me-in-production-use-long-random-string
JWT_ACCESS_EXPIRE_SECONDS=3600
JWT_REFRESH_EXPIRE_DAYS=30
BASE_URL=http://localhost:8000
CORS_ORIGINS=*

# Supabase Auth (Path A — phone OTP). JWT secret: Project Settings → API → JWT Secret
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_JWT_SECRET=
# Optional — admin tasks only; never ship to the mobile app
SUPABASE_SERVICE_ROLE_KEY=

# Twilio Verify (Path B — phone sign-up/login). When all three vars below are set,
# /auth/register and /auth/login phone-code flows switch to Twilio Verify.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# Payments (PROG-408/409). Leave PAYMENTS_SIMULATED=true until keys are configured.
# To go live: set the Stripe keys below AND PAYMENTS_SIMULATED=false — that single flag
# switches ON the real card-save (SetupIntent/PaymentSheet), Connect payouts, and the
# PaymentIntent checkout charge together.
PAYMENTS_SIMULATED=true
STRIPE_SECRET_KEY=
# Publishable key is returned to the app for PaymentSheet (also set it on the mobile .env).
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Currency charged to buyers (AUD now; CNY later per PRD).
DEFAULT_CHARGE_CURRENCY=aud
# Stripe Connect Express payout onboarding deep links (return to the app).
CONNECT_RETURN_URL=heishi://payout/connect/return
CONNECT_REFRESH_URL=heishi://payout/connect/refresh
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
