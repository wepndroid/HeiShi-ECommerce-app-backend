# HeyMarket Backend environment
# Railway sets PORT automatically. The Procfile uses it; do not add PORT unless
# you are overriding the Railway runtime yourself.

# Database
# Railway Postgres usually provides DATABASE_URL automatically when a Postgres
# service is attached. SQLAlchemy accepts postgresql://... URLs.
DATABASE_URL=postgresql+psycopg2://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres?sslmode=require

# Security/session
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_ACCESS_EXPIRE_SECONDS=3600
JWT_REFRESH_EXPIRE_DAYS=30

# Public backend URL and browser/app access
# Set BASE_URL to the deployed Railway URL, for example:
# https://your-backend.up.railway.app
BASE_URL=http://localhost:8000
CORS_ORIGINS=*

# Storage
# Use supabase for production user uploads. Use local only for local development
# or a temporary Railway Volume deployment.
STORAGE_BACKEND=supabase
SUPABASE_STORAGE_BUCKET=listing-images
SUPABASE_STORAGE_PATH_PREFIX=uploads

# Local fallback storage. Railway filesystem is ephemeral unless you attach a
# Volume. If using a Volume, mount it and point UPLOAD_DIR to that mount, for
# example /data/uploads.
UPLOAD_DIR=uploads

# Marketplace/order behavior
ESCROW_FEE=0.0
AUD_TO_CNY_DISPLAY_RATE=4.75
PENDING_PAY_EXPIRE_MINUTES=30

# Global notification/profile defaults
CHAT_MESSAGES=true
REMIND_PAY=true
REMIND_SHIP=true
SHOW_WECHAT_BADGE=false

# Seeded admin account. Change both values before first production boot.
ADMIN_SEED_PHONE=0499999001
ADMIN_SEED_PASSWORD=change-me-before-production

# Never expose OTP codes from production API responses.
EXPOSE_DEV_OTP=false

# Supabase Auth. JWT secret: Supabase Project Settings -> API -> JWT Secret.
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_JWT_SECRET=
# Required when STORAGE_BACKEND=supabase. Backend-only secret; never ship this to the mobile app.
SUPABASE_SERVICE_ROLE_KEY=

# WeChat Open Platform login. The mobile app obtains a one-time auth code from
# the native WeChat SDK; /auth/wechat exchanges it with these server-side values.
WECHAT_OPEN_APP_ID=
WECHAT_OPEN_APP_SECRET=

# Twilio Verify. When all three vars are set, phone sign-up/login use Twilio.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# Payments. Leave PAYMENTS_SIMULATED=true until Stripe is fully configured.
# To use real Stripe checkout, escrow, refunds, and Connect transfers:
# set Stripe keys below and PAYMENTS_SIMULATED=false.
PAYMENTS_SIMULATED=true
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
DEFAULT_CHARGE_CURRENCY=aud

# Stripe Connect Express payout onboarding return/refresh deep links.
CONNECT_RETURN_URL=heishi://payout/connect/return
CONNECT_REFRESH_URL=heishi://payout/connect/refresh

# PayPal payout/checkout integration
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# Alipay payout integration
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=

# WeChat Pay payout integration
WECHAT_PAY_APP_ID=
WECHAT_PAY_MCH_ID=
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_SERIAL_NO=
WECHAT_PAY_PRIVATE_KEY=
